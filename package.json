{
  "name": "chatty",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm -C web dev",
    "dev:api": "uv run python main.py",
    "build": "pnpm -C web build",
    "test": "uv run pytest -q && pnpm -C web test:frontend",
    "typecheck": "uv run ty check && pnpm -C web typecheck",
    "lint": "uv run ruff check . && pnpm -C web lint",
    "lint:fix": "uv run ruff check . --fix && pnpm -C web lint:fix",
    "test:frontend": "pnpm -C web test:frontend",
    "test:e2e": "pnpm -C web test:e2e",
    "test:deepseek": "uv run pytest -m deepseek -q",
    "test:coverage": "pnpm -C web test:coverage",
    "eval": "uv run python -m chatty.eval",
    "backup": "uv run python -m chatty.backup"
  }
}
