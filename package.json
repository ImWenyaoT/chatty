{
  "name": "chatty",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "workspaces": [
    "packages/*",
    "rag-service",
    "rag-service/dashboard",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter rental-rag-service dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "build:rag-service": "pnpm --filter rental-rag-service build",
    "build:skeleton": "tsc -b packages/shared packages/db packages/agent-core packages/llm --pretty false",
    "typecheck:skeleton": "pnpm build:skeleton && pnpm --filter @rental/agent-core typecheck && pnpm --filter @rental/llm typecheck"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@openai/agents": "^0.12.0",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  }
}
