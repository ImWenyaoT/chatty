{
  "name": "chatty",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @chatty/web dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p eval/tsconfig.json --noEmit",
    "lint": "eslint . && prettier \"**/*.{js,jsx,ts,tsx,json,css,yml,yaml}\" --check",
    "lint:fix": "eslint . --fix && prettier \"**/*.{js,jsx,ts,tsx,json,css,yml,yaml}\" --write",
    "test:frontend": "pnpm --filter @chatty/web test:frontend",
    "test:control-plane-integration": "pnpm --filter @chatty/web exec node --test --import tsx lib/customer-service-turn.test.ts lib/background-job-worker.test.ts lib/memory-control-plane.test.ts lib/context-control.test.ts lib/control-plane-read-model.test.ts lib/control-plane-api-render.test.ts && pnpm test:worker-integration",
    "build:skeleton": "tsc -b packages/shared packages/db packages/agent-core packages/llm --pretty false",
    "typecheck:skeleton": "pnpm build:skeleton && pnpm --filter @rental/agent-core typecheck && pnpm --filter @rental/llm typecheck",
    "smoke": "pnpm build:skeleton && node scripts/smoke.mts",
    "eval": "pnpm build:skeleton && node --import tsx eval/run.ts",
    "worker": "node --env-file-if-exists=.env --import tsx scripts/worker.mts",
    "worker:once": "node --env-file-if-exists=.env --import tsx scripts/worker.mts --once",
    "test:worker-integration": "node --import tsx scripts/worker-integration.mts",
    "test:deepseek-contracts": "pnpm --filter @rental/llm test:deepseek-contracts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rental/agent-core": "workspace:*",
    "@rental/db": "workspace:*",
    "@rental/llm": "workspace:*",
    "@rental/shared": "workspace:*",
    "@types/node": "^22.13.10",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "yaml": "^2.8.3"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
