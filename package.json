{
  "name": "chatty",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "rag-service",
    "rag-service/dashboard"
  ],
  "scripts": {
    "dev": "pnpm --filter @chatty/web dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build:rag-service": "pnpm --filter rental-rag-service build",
    "build:skeleton": "tsc -b packages/shared packages/domain packages/db packages/agent-core packages/llm --pretty false",
    "typecheck:skeleton": "pnpm build:skeleton && pnpm --filter @rental/domain typecheck && pnpm --filter @rental/agent-core typecheck && pnpm --filter @rental/llm typecheck",
    "smoke": "pnpm build:skeleton && node scripts/smoke.mts",
    "promote:failure-case": "pnpm build:skeleton && node scripts/promote-failure-case.mts"
  },
  "devDependencies": {
    "@rental/agent-core": "workspace:*",
    "@rental/db": "workspace:*",
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
