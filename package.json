{
  "name": "chatty",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "rag-service"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build:rag-service": "npm --workspace rental-rag-service run build",
    "build:skeleton": "tsc -b packages/shared packages/db packages/agent-core packages/llm --pretty false",
    "typecheck:skeleton": "npm run build:skeleton && npm run typecheck --workspace @rental/agent-core && npm run typecheck --workspace @rental/llm"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@openai/agents": "^0.12.0",
    "openai": "^6.45.0",
    "zod": "^4.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
