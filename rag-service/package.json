{
  "name": "rental-rag-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/src/server.js",
    "ingest": "tsx scripts/ingest.ts",
    "eval": "tsx scripts/eval.ts",
    "build:dashboard": "pnpm --dir dashboard build",
    "dev:dashboard": "pnpm --dir dashboard dev",
    "dev:setup": "bash scripts/dev-setup.sh",
    "qdrant:start": "docker run -d --name rental-qdrant -p 6333:6333 -p 6334:6334 -v qdrant_storage:/qdrant/storage qdrant/qdrant",
    "qdrant:stop": "docker stop rental-qdrant",
    "qdrant:rm": "docker rm -f rental-qdrant"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.18.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "fastify-plugin": "^6.0.0",
    "openai": "^6.45.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
