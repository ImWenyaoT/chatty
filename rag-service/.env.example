OPENAI_API_KEY=
OPENAI_BASE_URL=

# 主对话模型（事实抽取、分类器、评估器都用这个）
CHAT_MODEL=gpt-5.2

# 客服回复生成专用模型（强烈建议用指令遵循更好的模型，比如 gpt-4o、claude-sonnet）
# 不设则自动退回 CHAT_MODEL
CHAT_MODEL_FOR_GENERATION=gpt-4o

# 评估器模型
EVALUATOR_MODEL=gpt-5.2

# Prompt 版本（对应 config/prompts/<version>.yaml）
PROMPT_VERSION=v1

EMBEDDING_MODEL=text-embedding-3-small
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=rental_knowledge
PORT=3001
TOP_K=5
