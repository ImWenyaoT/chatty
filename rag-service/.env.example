MIMO_API_KEY=
MIMO_BASE_URL=

# 主对话模型（事实抽取、分类器、评估器都用这个）
MIMO_MODEL=mimo-2.5

# 客服回复生成专用模型。不设则自动退回 MIMO_MODEL
MIMO_MODEL_FOR_GENERATION=mimo-2.5

# 评估器模型
MIMO_EVALUATOR_MODEL=mimo-2.5

# Prompt 版本（对应 config/prompts/<version>.yaml）
PROMPT_VERSION=v1

EMBEDDING_MODEL=text-embedding-3-small
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=rental_knowledge
PORT=3001
TOP_K=5
