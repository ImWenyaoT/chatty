{
  "name": "@chatty/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @chatty/agent build",
    "dev": "node scripts/next.mjs dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "node scripts/next.mjs start --hostname 127.0.0.1",
    "lint": "eslint . && prettier . --ignore-path ../../.gitignore --ignore-path .prettierignore --check",
    "lint:fix": "eslint . --fix && prettier . --ignore-path ../../.gitignore --ignore-path .prettierignore --write",
    "test": "node --test --import tsx \"lib/**/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:frontend": "node --test --import tsx \"lib/frontend-contract.test.ts\"",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include='lib/**' --test-coverage-lines=89 --test-coverage-branches=75 --test-coverage-functions=84 --test --import tsx \"lib/**/*.test.ts\"",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chatty/agent": "workspace:*",
    "@chatty/contracts": "workspace:*",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/postcss": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "globals": "^17.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
