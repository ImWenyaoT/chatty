{
  "name": "@chatty/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./application-factory": {
      "types": "./src/application-factory.ts",
      "default": "./dist/application-factory.js"
    },
    "./browser-smoke": {
      "types": "./src/browser-smoke.ts",
      "default": "./dist/browser-smoke.js"
    },
    "./http-application": {
      "types": "./src/http-application.ts",
      "default": "./dist/http-application.js"
    }
  },
  "scripts": {
    "demo": "tsx src/demo-main.ts",
    "eval": "tsx src/eval-main.ts --cases ../../eval/cases.jsonl --output ../../eval/results.jsonl --workdir ../../.cache/eval",
    "build": "tsup",
    "backup": "tsx src/backup-main.ts",
    "lint": "eslint . && prettier . --check",
    "lint:fix": "eslint . --fix && prettier . --write",
    "test": "node --test --import tsx \"test/**/*.test.ts\"",
    "test:resume-contract": "node --test --import tsx test/resume-contract.test.ts",
    "test:deepseek": "CHATTY_RUN_DEEPSEEK=1 node --env-file=../../.env --test --import tsx test/deepseek-contract.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chatty/contracts": "workspace:*",
    "@openai/agents": "^0.13.5",
    "unicode-case-folding": "1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.13.3",
    "eslint": "^9.39.4",
    "globals": "^17.3.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
