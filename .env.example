# Chatty — shared environment variables
#
# These are read by the Next.js stack (packages/llm, apps/web) and the eval
# harness (eval/). Keep the names identical across both so a single local env
# drives everything. Copy this file to `.env` and fill in your values.
#
# Chatty is DeepSeek-first. `OPENAI_*` are compatibility variable names for the
# OpenAI-format SDK/client, not a signal that the target model is OpenAI.
# Pin the pro tier, NOT the `deepseek-chat` alias (deprecated 2026-07-24 and
# mapped to flash compatibility behavior by DeepSeek docs).

OPENAI_API_KEY=your_key
OPENAI_BASE_URL=https://api.deepseek.com/beta
CHAT_MODEL=deepseek-v4-pro

# Optional: model for the eval LLM-judge (eval/judge.ts). Unset => CHAT_MODEL.
# EVALUATOR_MODEL=

# Chatty-specific
# SQLite database file (unset => ':memory:', same code path without durability).
CHATTY_DB_PATH=./data/chatty.db
# Chatty web port (Next.js dev server)
PORT_WEB=3000
# Optional shared-key gate for /api/playground. Unset => open (zero-config dev).
# Set on a deployed instance and send it as the `x-api-key` request header.
# CHATTY_API_KEY=
