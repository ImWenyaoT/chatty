# Chatty — shared environment variables
#
# These are read by both the new Next.js stack (packages/llm, apps/web) and the
# legacy rag-service. Keep the names identical across both so a single local env
# drives everything. Copy this file to `.env` and fill in your values.
#
# The whole stack is provider-agnostic: any OpenAI-compatible endpoint works by
# pointing OPENAI_BASE_URL at it.
#   DeepSeek (local dev default) — pin the pro tier, NOT the deepseek-chat alias
#   (alias resolves to deepseek-v4-flash, which drops JSON after tool calls):
#     OPENAI_BASE_URL=https://api.deepseek.com/v1
#     CHAT_MODEL=deepseek-v4-pro
#   Groq (fast SRAM inference):
#     OPENAI_BASE_URL=https://api.groq.com/openai/v1
#     CHAT_MODEL=llama-3.3-70b-versatile
#   Cerebras (fast SRAM inference, hosts Qwen):
#     OPENAI_BASE_URL=https://api.cerebras.ai/v1
#     CHAT_MODEL=qwen-3-32b

OPENAI_API_KEY=your_key
OPENAI_BASE_URL=https://api.deepseek.com/v1
CHAT_MODEL=deepseek-v4-pro

# Opt-in LLM compose path for /api/playground. Double gate: set CHATTY_LLM=1
# AND provide OPENAI_API_KEY above, otherwise the harness uses its
# deterministic composer (also the fallback whenever the model call fails).
# CHATTY_LLM=1

# Optional knobs (unset = sensible defaults inherited from rag-service naming).
# EVALUATOR_MODEL=
# EMBEDDING_MODEL=
# PROMPT_VERSION=v1

# Eval-only: per-target chat model override for the dual-target golden runner
# (rag-service/scripts/eval.ts). Both lanes read CHAT_MODEL by default; set these
# to peel the legacy control lane onto a tool_choice-capable non-thinking model
# while the harness lane keeps deepseek-v4-pro (legacy's forced tool_choice is
# rejected by thinking-mode models). Only the env matching --target takes effect.
# LEGACY_CHAT_MODEL=
# HARNESS_CHAT_MODEL=

# Chatty-specific
# SQLite database file (unset => ':memory:', same code path without durability).
CHATTY_DB_PATH=./data/chatty.db
# Chatty web port (Next.js dev server)
PORT_WEB=3000
# Optional shared-key gate for /api/playground. Unset => open (zero-config dev).
# Set on a deployed instance and send it as the `x-api-key` request header.
# CHATTY_API_KEY=
