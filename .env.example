# Chatty — shared environment variables
#
# These are read by both the new Next.js stack (packages/llm, apps/web) and the
# legacy rag-service. Keep the names identical across both so a single local env
# drives everything. Copy this file to `.env` and fill in your values.
#
# The whole stack is provider-agnostic: any OpenAI-compatible endpoint works by
# pointing OPENAI_BASE_URL at it. DeepSeek local dev example:
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   CHAT_MODEL=deepseek-chat

OPENAI_API_KEY=your_key
OPENAI_BASE_URL=https://api.deepseek.com/v1
CHAT_MODEL=deepseek-chat

# OpenAI Agents SDK lane (Phase 4). Optional dual-provider config: route the SDK
# agent run to a different endpoint (e.g. real OpenAI) while classification /
# extraction / eval stay on the cheaper CHAT_MODEL above. If unset, the SDK lane
# falls back to the shared OPENAI_* / CHAT_MODEL values.
# OPENAI_AGENTS_API_KEY=sk-...
# OPENAI_AGENTS_BASE_URL=https://api.openai.com/v1
# AGENTS_SDK_MODEL=gpt-4o-mini

# Optional knobs (unset = sensible defaults inherited from rag-service naming).
# EVALUATOR_MODEL=
# EMBEDDING_MODEL=
# PROMPT_VERSION=v1

# Chatty-specific
# Enable the SQLite write path (off => JSON fallback, legacy behaviour preserved).
CHATTY_SQLITE=1
CHATTY_DB_PATH=./data/chatty.db
# Chatty web port (Next.js dev server)
PORT_WEB=3000
# Optional shared-key gate for /api/playground. Unset => open (zero-config dev).
# Set on a deployed instance and send it as the `x-api-key` request header.
# CHATTY_API_KEY=
